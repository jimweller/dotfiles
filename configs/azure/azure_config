[cloud]
name = AzureCloud

[core]
first_run = yes
collect_telemetry = false
no_color = true
login_experience_v2 = off
disable_confirm_prompt = true
only_show_errors = true
survey_message = no

[logging]
enable_log_file = false

[defaults]
location = westus2

[extension]
auto-upgrade = yes_without_prompt

[auto-upgrade]
enable = false
