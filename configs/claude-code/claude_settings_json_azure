{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_USE_FOUNDRY": "1",
    "CLAUDE_CODE_USE_BEDROCK": "0",
    "CLAUDE_CODE_SHELL": "bash",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5",
    "ANTHROPIC_MODEL": "claude-opus-4-6[1m]",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "40",
    "ENABLE_TOOL_SEARCH": "auto:1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_COST_WARNINGS": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "model": "claude-opus-4-6[1m]",
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ingest-transcript.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ingest-transcript.sh"
          }
        ]
      },
      {
        "matcher": "prompt_input_exit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ingest-transcript.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-phrase-guard.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh azure"
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "agent-browser@agent-browser": true,
    "mcg-atlassian@sead-claude-marketplace": true,
    "mcg-status-updates@devx-claude-marketplace": true,
    "mcg-lookup@sead-claude-marketplace": true,
    "employee-termination@devx-claude-marketplace": true,
    "beads@beads-marketplace": true,
    "claude-mem@jimweller": true,
    "superpowers@jimweller": true
  },
  "extraKnownMarketplaces": {
    "devx-claude-marketplace": {
      "source": {
        "source": "git",
        "url": "https://dev.azure.com/mcgsead/devx-internal/_git/devx-claude-marketplace"
      },
      "autoUpdate": true
    },
    "beads-marketplace": {
      "source": {
        "source": "github",
        "repo": "gastownhall/beads"
      }
    },
    "jimweller": {
      "source": {
        "source": "github",
        "repo": "jimweller/claude-marketplace"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "CLANKING"
    ]
  },
  "effortLevel": "xhigh",
  "awaySummaryEnabled": false,
  "autoUpdatesChannel": "latest",
  "prefersReducedMotion": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "preferredNotifChannel": "notifications_disabled",
  "terminalProgressBarEnabled": false
}
