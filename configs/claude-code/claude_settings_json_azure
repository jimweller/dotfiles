{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_USE_FOUNDRY": "1",
    "CLAUDE_CODE_SHELL": "bash",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-7[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5",
    "ANTHROPIC_MODEL": "claude-opus-4-7[1m]",
    "CLAUDE_CODE_SUBAGENT_MODEL": "claude-sonnet-4-6",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "40",
    "ENABLE_TOOL_SEARCH": "auto:1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "DISABLE_FEEDBACK_COMMAND": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_COST_WARNINGS": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ingest-transcript.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ingest-transcript.sh"
          }
        ]
      },
      {
        "matcher": "prompt_input_exit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ingest-transcript.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lsp-first-guard.js"
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lsp-first-glob-guard.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/bash-grep-block.js"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lsp-first-read-guard.js"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lsp-pre-delegation.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/command-safety-scanner.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__cclsp__find_definition|mcp__cclsp__find_references|mcp__cclsp__find_workspace_symbols|mcp__cclsp__find_implementation|mcp__cclsp__get_hover|mcp__cclsp__get_diagnostics|mcp__cclsp__get_incoming_calls|mcp__cclsp__get_outgoing_calls|mcp__serena__find_symbol|mcp__serena__find_referencing_symbols|mcp__serena__get_symbols_overview",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lsp-usage-tracker.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "true",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/lsp-session-reset.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop-phrase-guard.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh azure"
  },
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true,
    "agent-browser@agent-browser": true,
    "mcg-atlassian@sead-claude-marketplace": true,
    "mcg-status-updates@devx-claude-marketplace": true,
    "mcg-lookup@sead-claude-marketplace": true,
    "claude-mem@jimweller": true,
    "employee-termination@devx-claude-marketplace": true
  },
  "extraKnownMarketplaces": {
    "devx-claude-marketplace": {
      "source": {
        "source": "git",
        "url": "https://dev.azure.com/mcgsead/devx-internal/_git/devx-claude-marketplace"
      },
      "autoUpdate": true
    },
    "jimweller": {
      "source": {
        "source": "git",
        "url": "https://github.com/jimweller/claude-mem.git"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "CLANKING"
    ]
  },
  "effortLevel": "xhigh",
  "awaySummaryEnabled": false,
  "autoUpdatesChannel": "latest",
  "prefersReducedMotion": true
}
