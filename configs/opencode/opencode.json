{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4",
  "provider": {
    "google": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      },
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro"
        },
        "gemini-3.5-flash": {
          "name": "Gemini 3.5 Flash"
        }
      },
      "whitelist": [
        "gemini-3.1-pro-preview",
        "gemini-3.5-flash"
      ]
    },
    "openai": {
      "options": {
        "apiKey": "{env:OPENAI_KEY}"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5"
        },
        "gpt-5.4": {
          "name": "GPT 5.4"
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini"
        }
      },
      "whitelist": [
        "gpt-5.5",
        "gpt-5.4",
        "gpt-5.4-mini"
      ]
    },
    "az-anthropic": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://mcg-dxclinical-fais.services.ai.azure.com/anthropic/v1",
        "apiKey": "{env:ANTHROPIC_FOUNDRY_API_KEY}"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6",
          "options": {
            "thinking": { "type": "enabled", "budgetTokens": 63999 }
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6"
        },
        "claude-haiku-4-5": {
          "name": "Claude Haiku 4.5"
        }
      },
      "whitelist": [
        "claude-opus-4-6",
        "claude-sonnet-4-6",
        "claude-haiku-4-5"
      ]
    }
  },
  "permission": "allow",
  "enabled_providers": ["google", "openai", "az-anthropic"],
  "mcp": {
    "c7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "environment": {
        "DEFAULT_MINIMUM_TOKENS": "10000"
      },
      "enabled": true
    },
    "g": {
      "type": "remote",
      "url": "http://localhost:9091/mcp/",
      "enabled": true
    },
    "repomix": {
      "type": "local",
      "command": ["npx", "-y", "repomix", "--mcp"],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": ["serena", "start-mcp-server", "--context=claude-code", "--project-from-cwd"],
      "enabled": true
    }
  }
}
