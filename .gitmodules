[submodule "dotbot"]
	path = submodules/dotbot
  url = https://github.com/anishathalye/dotbot
  ignore = dirty
  shallow = true
[submodule "devcontainer"]
	path = submodules/devcontainer
  url = https://github.com/jimweller/devcontainer
  ignore = dirty
  branch = main
  shallow = true
[submodule "antidote"]
	path = submodules/antidote
  url = https://github.com/getantidote/antidote
  ignore = dirty
  branch = main
  shallow = true
[submodule "dotfiles/claude-code/tools/total-recall"]
	path = configs/claude-code/tools/total-recall
	url = git@github.com:jimweller/total-recall.git
[submodule "dotfiles/claude-code/tools/lsp-enforcement-kit"]
	path = configs/claude-code/tools/lsp-enforcement-kit
	url = https://github.com/jimweller/claude-code-lsp-enforcement-kit.git
[submodule "dotfiles/claude-code/tools/humble-master"]
	path = configs/claude-code/tools/humble-master
	url = https://github.com/jimweller/humble-master.git
