<mxfile host="app.diagrams.net" agent="Claude" version="26.0.0">
  <diagram id="token-lifecycle" name="AWS SSO Token Lifecycle">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="AWS SSO Token Lifecycle" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- launchd trigger -->
        <mxCell id="launchd" value="&lt;b&gt;launchd&lt;/b&gt;&lt;br&gt;00:00 / 09:00 / 18:00&lt;br&gt;&lt;i&gt;RunAtLoad: true&lt;/i&gt;" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="200" height="80" as="geometry" />
        </mxCell>

        <!-- Script box -->
        <mxCell id="script" value="&lt;b&gt;aws-refresh-token.sh&lt;/b&gt;" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="400" y="130" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow: launchd -> script -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="launchd" target="script" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e1label" value="triggers" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=11;" vertex="1" connectable="0" parent="e1">
          <mxGeometry x="-0.1" relative="1" as="geometry" />
        </mxCell>

        <!-- Layer 1: Client Registration -->
        <mxCell id="layer1" value="&lt;b&gt;Layer 1: Client Registration&lt;/b&gt;&lt;br&gt;Duration: 90 days&lt;br&gt;OIDC trusted device registration&lt;br&gt;&lt;br&gt;&lt;i&gt;~/.aws/sso/cache/*.json&lt;/i&gt;&lt;br&gt;Fields: clientId, clientSecret,&lt;br&gt;registrationExpiresAt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="80" y="290" width="260" height="140" as="geometry" />
        </mxCell>

        <!-- Layer 2: SSO Session -->
        <mxCell id="layer2" value="&lt;b&gt;Layer 2: SSO Session&lt;/b&gt;&lt;br&gt;Duration: 8 hours (admin-configured)&lt;br&gt;Your actual login session&lt;br&gt;&lt;br&gt;&lt;i&gt;~/.aws/sso/cache/*.json&lt;/i&gt;&lt;br&gt;Fields: accessToken (~1hr, auto-renewed),&lt;br&gt;refreshToken (8hr lifetime)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=center;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="440" y="290" width="280" height="140" as="geometry" />
        </mxCell>

        <!-- Layer 3: Temporary IAM Credentials -->
        <mxCell id="layer3" value="&lt;b&gt;Layer 3: Temporary IAM Credentials&lt;/b&gt;&lt;br&gt;Duration: 12 hours (admin-configured)&lt;br&gt;Actual AWS API credentials&lt;br&gt;&lt;br&gt;&lt;i&gt;~/.aws/cli/cache/*.json&lt;/i&gt;&lt;br&gt;Fields: AccessKeyId, SecretAccessKey,&lt;br&gt;SessionToken, Expiration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="820" y="290" width="280" height="140" as="geometry" />
        </mxCell>

        <!-- Layer 4: Export File -->
        <mxCell id="layer4" value="&lt;b&gt;Layer 4: Custom Export File&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;i&gt;~/assets/aws/aws-token.json&lt;/i&gt;&lt;br&gt;Served by credential_process&lt;br&gt;in ~/.aws/config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=center;verticalAlign=top;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="1200" y="290" width="240" height="140" as="geometry" />
        </mxCell>

        <!-- Step 1: aws sso login -->
        <mxCell id="step1" value="&lt;b&gt;Step 1&lt;/b&gt;&lt;br&gt;aws sso login" style="shape=step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;size=20;" vertex="1" parent="1">
          <mxGeometry x="170" y="500" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Step 2: Clear cache -->
        <mxCell id="step2" value="&lt;b&gt;Step 2&lt;/b&gt;&lt;br&gt;Clear CLI cache" style="shape=step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;size=20;" vertex="1" parent="1">
          <mxGeometry x="470" y="500" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Step 3: Export credentials -->
        <mxCell id="step3" value="&lt;b&gt;Step 3&lt;/b&gt;&lt;br&gt;aws configure&lt;br&gt;export-credentials" style="shape=step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;size=20;" vertex="1" parent="1">
          <mxGeometry x="770" y="500" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Step 4: Write export file -->
        <mxCell id="step4" value="&lt;b&gt;Step 4&lt;/b&gt;&lt;br&gt;Write aws-token.json" style="shape=step;perimeter=stepPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;size=20;" vertex="1" parent="1">
          <mxGeometry x="1070" y="500" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow: script -> step1 -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="script" target="step1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow: step1 -> layer1 (uses) -->
