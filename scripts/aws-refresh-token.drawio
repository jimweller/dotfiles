        <mxCell id="e3label" value="uses 90-day&lt;br&gt;registration to&lt;br&gt;renew session" style="edgeLabel;html=1;align=center;verticalAlign=middle;fontSize=10;" vertex="1" connectable="0" parent="e3">
          <mxGeometry x="-0.2" relative="1" as="geometry" />
        </mxCell>

